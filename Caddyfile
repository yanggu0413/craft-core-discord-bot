# ===================================================
# 網頁主儀表板 (Web Dashboard)
# 域名：dash.craft-core.xyz
# ===================================================
dash.craft-core.xyz {
    encode zstd gzip

    # 1. 所有 API 請求轉發至後端 API 服務 (Port 3000)
    handle /api/* {
        reverse_proxy localhost:3000
    }

    # 2. 將即時同步的 WebSocket 連線轉發至後端 (Port 3000)
    handle /ws {
        reverse_proxy localhost:3000
    }

    # 3. 其他所有請求（包含 React/Vite 路由）交給靜態檔案伺服器直接服務
    handle {
        root * /var/www/craft-core/dashboard
        file_server
        try_files {path} /index.html
    }
}
